# Local PostgreSQL
DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/jaehkim_research"
DIRECT_URL="postgresql://postgres:PASSWORD@localhost:5432/jaehkim_research"

# Production example (EC2 + RDS)
# DATABASE_URL="postgresql://app_user:PASSWORD@jaehkim-research-db.xxxxx.ap-northeast-2.rds.amazonaws.com:5432/jaehkim_research"
# DIRECT_URL="postgresql://app_user:PASSWORD@jaehkim-research-db.xxxxx.ap-northeast-2.rds.amazonaws.com:5432/jaehkim_research"

# NextAuth.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin Credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="generate-with-scripts/hash-password.ts"
ADMIN_EMAIL="your-email@gmail.com"

# Resend (Email)
RESEND_API_KEY="re_your_api_key_here"

# Site URL (for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Production example domain on EC2
# NEXTAUTH_URL="https://research.example.com"
# NEXT_PUBLIC_SITE_URL="https://research.example.com"

# Vercel Blob (legacy optional path)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Storage Provider (auto | vercel-blob | local | s3)
# - auto: uses vercel-blob when BLOB_READ_WRITE_TOKEN is set, otherwise local
# - s3: uploads to AWS S3 and returns CloudFront/S3 public URL
STORAGE_PROVIDER="local"

# Production example
# STORAGE_PROVIDER="s3"

# Email Provider (auto | resend | noop | ses)
# - auto: uses resend when RESEND_API_KEY is set, otherwise noop
# - ses: reserved for future AWS SES migration
EMAIL_PROVIDER="auto"
EMAIL_FROM="JaehKim Research <onboarding@resend.dev>"

# AWS
AWS_REGION="ap-northeast-2"
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_SESSION_TOKEN="..."

# S3 / CloudFront
# S3_BUCKET_NAME="jaehkim-research-assets-prod"
# S3_PUBLIC_BASE_URL="https://cdn.example.com"
# CLOUDFRONT_URL="https://dxxxxxxxxxxxx.cloudfront.net"
