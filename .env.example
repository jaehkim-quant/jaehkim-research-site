# Supabase (PostgreSQL)
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT-REF.supabase.co:5432/postgres"

# NextAuth.js
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin Credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="generate-with-scripts/hash-password.ts"
ADMIN_EMAIL="your-email@gmail.com"

# Resend (Email)
RESEND_API_KEY="re_your_api_key_here"

# Site URL (for SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# Vercel Blob (optional, for image upload in production)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Storage Provider (auto | vercel-blob | local | s3)
# - auto: uses vercel-blob when BLOB_READ_WRITE_TOKEN is set, otherwise local
# - s3: reserved for AWS migration (provider boundary is ready; implementation needed before production use)
STORAGE_PROVIDER="auto"

# Email Provider (auto | resend | noop | ses)
# - auto: uses resend when RESEND_API_KEY is set, otherwise noop
# - ses: reserved for AWS migration (provider boundary is ready; implementation needed before production use)
EMAIL_PROVIDER="auto"
EMAIL_FROM="JaehKim Research <onboarding@resend.dev>"

# AWS (future migration placeholders)
AWS_REGION="ap-northeast-2"
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."

# S3 / CloudFront (future migration placeholders)
# S3_BUCKET_NAME="jaehkim-research-assets"
# S3_PUBLIC_BASE_URL="https://cdn.example.com"
# CLOUDFRONT_URL="https://dxxxxxxxxxxxx.cloudfront.net"

# Optional: when using RDS/RDS Proxy later, point Prisma here
# DATABASE_URL="postgresql://..."
# DIRECT_URL="postgresql://..."
