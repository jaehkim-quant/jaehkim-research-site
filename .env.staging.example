# Staging app URL
NEXTAUTH_URL="https://staging-research.example.com"
NEXT_PUBLIC_SITE_URL="https://staging-research.example.com"
NEXTAUTH_SECRET="replace-with-staging-secret"

# RDS staging database
DATABASE_URL="postgresql://app_user:PASSWORD@staging-db.xxxxx.ap-northeast-2.rds.amazonaws.com:5432/jaehkim_research_staging"
DIRECT_URL="postgresql://app_user:PASSWORD@staging-db.xxxxx.ap-northeast-2.rds.amazonaws.com:5432/jaehkim_research_staging"

# Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="replace-with-bcrypt-hash"
ADMIN_EMAIL="your-email@example.com"

# Email
EMAIL_PROVIDER="auto"
EMAIL_FROM="JaehKim Research <onboarding@resend.dev>"
RESEND_API_KEY="re_staging_key"

# Storage
STORAGE_PROVIDER="s3"
AWS_REGION="ap-northeast-2"
S3_BUCKET_NAME="jaehkim-research-assets-staging"
CLOUDFRONT_URL="https://dxxxxxxxxxxxx.cloudfront.net"

# Optional AWS credentials for local/docker use
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_SESSION_TOKEN="..."
